# Local bootstrap overrides and secrets (gitignored).
#
#   cp bootstrap/env/bootstrap.env.example bootstrap/env/bootstrap.env

# ARGOCD_OVERLAY=dev

# Private GitHub — ${VAR} in argocd/repos/repo-creds.*.yaml (envsubst at install)
# GITHUB_PAT=
# GITHUB_SSH_PRIVATE_KEY_B64=

# Argo CD UI (user admin). Patched after Helm if set — not via Helm values (SSA conflict).
# ARGOCD_ADMIN_PASSWORD=
