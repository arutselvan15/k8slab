# Committed bootstrap defaults (safe to commit). Override in bootstrap.env (gitignored).

# Helm chart pin: https://github.com/argoproj/argo-helm/tree/main/charts/argo-cd
ARGO_CD_CHART_VERSION=9.5.21

# Helm values overlay when not passed on the CLI (dev | stg | prod)
ARGOCD_OVERLAY=dev

# Must match gitops Application repoURL and argocd/repos/repo.k8s-platform.yaml
GIT_REPO_URL=https://github.com/arutselvan15/k8s-platform.git
